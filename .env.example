# Required
ANTHROPIC_API_KEY=sk-ant-...

# Model — Sonnet 4.5 by default (2x cheaper than 4.7, vision-capable)
RESEARCH_MODEL=claude-sonnet-4-5-20250929

# false = visible Chromium window (good for debugging)
# true  = unattended/headless (production)
HEADLESS=false

# Where per-task results JSON files land (one per run, timestamped)
RESULTS_DIR=./results
